<h1>G-Scores</h1>

<%= form_with url: students_path, method: :get, local: true do %>
  <%= label_tag :registration_number, "Số báo danh" %>
  <%= text_field_tag :registration_number, params[:registration_number], placeholder: "Nhập số báo danh" %>
  <%= submit_tag "Tra cứu" %>
<% end %>

<% if params[:registration_number].present? %>
  <% if @student.present? %>
    <h2>Kết quả</h2>
    <p><strong>Số báo danh:</strong> <%= @student.registration_number %></p>

    <table>
      <thead>
        <tr>
          <th>Môn</th>
          <th>Điểm</th>
        </tr>
      </thead>
      <tbody>
        <% @subjects.each do |subject| %>
          <tr>
            <td><%= subject.label %></td>
            <td><%= @student.public_send(subject.key).presence || "-" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>Không tìm thấy số báo danh.</p>
  <% end %>
<% end %>