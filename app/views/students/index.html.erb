<section class="card">
  <h2>User Registration</h2>

  <%= form_with url: students_path, method: :get, local: true, class: "search-form" do %>
    <%= label_tag :registration_number, "Registration Number:" %>

    <div class="form-row">
      <%= text_field_tag :registration_number, params[:registration_number], placeholder: "Enter registration number" %>
      <%= submit_tag "Submit" %>
    </div>
  <% end %>
</section>

<section class="card">
  <h2>Detailed Scores</h2>

  <% if params[:registration_number].blank? %>
    <p class="muted">Detailed view of search scores here!</p>
  <% elsif @student.present? %>
    <p class="student-id">
      SBD:
      <strong><%= @student.registration_number %></strong>
    </p>

    <% scores = @subjects.map { |subject| @student.public_send(subject.key) }.compact %>

    <% if scores.any? %>
      <p class="summary-score">
        Average:
        <strong><%= (scores.sum / scores.count).round(2) %></strong>
      </p>
    <% end %>

    <table class="data-table">
      <thead>
        <tr>
          <th>Subject</th>
          <th>Score</th>
        </tr>
      </thead>
      <tbody>
        <% @subjects.each do |subject| %>
          <% score = @student.public_send(subject.key) %>

          <tr>
            <td><%= subject.label %></td>
            <td class="<%= "high-score" if score.present? && score >= 8 %>">
              <%= score.presence || "-" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="error">Registration number not found.</p>
  <% end %>
</section>